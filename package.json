{
  "name": "van-vliet-os-desktop",
  "productName": "Van Vliet OS",
  "version": "1.0.0",
  "description": "Van Vliet OS — intern besturingssysteem voor Van Vliet | Newwen (desktop-app rondom de web-app).",
  "author": "Van Vliet | Newwen",
  "license": "UNLICENSED",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win nsis --x64 --publish never",
    "build:mac": "electron-builder --mac dmg --universal --publish never"
  },
  "build": {
    "appId": "nl.vanvliet.os",
    "productName": "Van Vliet OS",
    "copyright": "Van Vliet | Newwen",
    "directories": { "output": "dist", "buildResources": "build" },
    "files": ["main.js", "splash.html", "build/icon.png", "build/icon-256.png", "!dist/**"],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico",
      "artifactName": "Van-Vliet-OS-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Van Vliet OS"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "build/icon.png",
      "category": "public.app-category.business",
      "artifactName": "Van-Vliet-OS.${ext}"
    },
    "dmg": { "title": "Van Vliet OS" }
  },
  "devDependencies": {
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8"
  }
}
